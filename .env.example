# App
APP_URL=http://localhost:3000
NODE_ENV=development
# Random 32+ char secret used to sign session cookies (openssl rand -hex 32)
SESSION_SECRET=dev-only-insecure-change-me-0000000000000000
ADMIN_EMAILS=anthony@profullstack.com

# Database
# Local dev: a file: URL points at a local SQLite file. Prod: Turso libsql URL.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Auth / email (optional in dev — verification links are logged to console if unset)
RESEND_API_KEY=
EMAIL_FROM=AIorNot.vote <hello@aiornot.vote>
EMAIL_VERIFICATION_TTL_MINUTES=30

# Uploads / storage (S3-compatible; Cloudflare R2 by default)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
MAX_IMAGE_UPLOAD_MB=12
MAX_VIDEO_UPLOAD_MB=75
MAX_VIDEO_DURATION_SECONDS=30

# Seed data
UNSPLASH_ACCESS_KEY=
OPENAI_API_KEY=
AI_IMAGE_MODEL=gpt-image-1
SEED_BATCH_SIZE=25

# RSS / rate-limit salts (openssl rand -hex 16)
RSS_CACHE_SECONDS=300
VOTE_SALT=dev-vote-salt
SUBMISSION_SALT=dev-submission-salt
RATE_LIMIT_SALT=dev-rate-limit-salt

# Analytics (optional)
POSTHOG_KEY=
POSTHOG_HOST=
